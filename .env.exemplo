# Dificuldade de Proof of Work
# 2 = ~1M tentativas/bloco (rápido, ~144 blocos/minuto)
# 3 = ~8M tentativas/bloco (8x mais lento)
# 4 = ~64M tentativas/bloco (muito lento)
DIFICULDADE=2

# Broker Kafka (não alterar se rodando no Docker)
KAFKA_BROKER=kafka:9092

# URL da Rede Central (não alterar se rodando no Docker)
REDE_CENTRAL_URL=http://rede-central:5000
